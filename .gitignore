# LanceDB — rebuilt from vault, never commit
.lancedb/
vault/lancedb_unified/

# Personal vault files — fill these in locally after cloning, never commit
# Templates (*.example) are committed; your filled versions are ignored
vault/Core/USER.md
vault/Core/SOUL.md
vault/Core/COMPANY-SOUL.md
vault/Core/ACTIVE_CONTEXT.md
vault/Core/SESSION_HANDOFF.md
vault/Core/FRESHNESS.md
vault/Core/CAPITAL_STATUS.md
vault/Core/EXECUTION_HANDOFF.md
vault/Archive/MEMORY.md

# Agent private namespaces — personality, memory, and session snapshots are personal
# vault/Agents/registry.yaml is committed (no personal data, just agent IDs)
vault/Agents/*/SOUL.md
vault/Agents/*/IDENTITY.md
vault/Agents/*/USER.md
vault/Agents/*/LAST_SESSION.md
vault/Agents/*/memory-*.md

# Migration output — analysis files are personal history, never commit
# The migration/ tool ships with the repo; vault/Migration/ output does not
vault/Migration/

# Root-level personal files
IDENTITY.md
USER.md

# Personal vault data — keep private
my-vault/
*.private.md

# Scripts with personal data (wallets, keys, agent configs)
scripts/wallets/

